<component type="desktop-application">
  <id>io.github.CertifiedSlop.AIppOpener</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <name>AIpp Opener</name>
  <summary>AI-powered application launcher for Linux</summary>
  
  <description>
    <p>
      AIpp Opener is an intelligent application launcher that uses natural language processing
      and AI to help you open applications quickly and efficiently.
    </p>
    <p>Features:</p>
    <ul>
      <li>Natural language commands ("open firefox", "launch vscode")</li>
      <li>AI-powered app suggestions</li>
      <li>Multiple interface options (CLI, GUI, system tray, voice)</li>
      <li>Keyboard shortcuts (Ctrl+Alt+Space)</li>
      <li>Web search fallback when apps aren't found</li>
      <li>Custom command aliases</li>
      <li>App groups/workspaces</li>
      <li>Plugin system for extensibility</li>
      <li>Dark/light theme support</li>
      <li>Usage history and predictions</li>
    </ul>
  </description>
  
  <launchable type="desktop-id">io.github.CertifiedSlop.AIppOpener.desktop</launchable>
  
  <screenshots>
    <screenshot type="default">
      <caption>AIpp Opener GUI with search results</caption>
    </screenshot>
  </screenshots>
  
  <url type="homepage">https://github.com/CertifiedSlop/AIpp-opener</url>
  <url type="bugtracker">https://github.com/CertifiedSlop/AIpp-opener/issues</url>
  <url type="donation">https://github.com/sponsors/CertifiedSlop</url>
  
  <provides>
